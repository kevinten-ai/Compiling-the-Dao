---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '一部融合修仙与编程的开源玄幻小说' } = Astro.props;
const basePath = '/Compiling-the-Dao';
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Noto+Serif+SC:wght@400;600;700&display=swap" rel="stylesheet" />
    <title>{title} | 编神纪</title>
  </head>
  <body class="bg-[#0d1117] text-[#c9d1d9] min-h-screen">
    <nav class="border-b border-[#30363d] bg-[#161b22]/80 backdrop-blur-sm sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href={basePath + '/'} class="flex items-center gap-2 hover:no-underline">
          <span class="text-[#58a6ff] font-mono text-lg">&gt;_</span>
          <span class="font-semibold">编神纪</span>
        </a>
        <div class="flex items-center gap-6 text-sm">
          <a href={basePath + '/read'} class="text-[#8b949e] hover:text-[#c9d1d9] transition-colors">阅读</a>
          <a href={basePath + '/world'} class="text-[#8b949e] hover:text-[#c9d1d9] transition-colors">世界观</a>
          <a href="https://github.com/kevinten-ai/Compiling-the-Dao" target="_blank" class="text-[#8b949e] hover:text-[#c9d1d9] transition-colors">GitHub</a>
        </div>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer class="border-t border-[#30363d] mt-16 py-8 text-center text-[#8b949e] text-sm">
      <p class="font-mono">"Fork the Dao, Commit the Truth."</p>
      <p class="mt-2">© 2024 编神纪 · CC BY-NC-SA 4.0</p>
    </footer>
  </body>
</html>
