---
import Layout from '../layouts/Layout.astro';

const basePath = '/Compiling-the-Dao';

const volumes = [
  {
    id: 'vol-01',
    title: 'Hello World',
    status: '已完结',
    chapters: [
      { num: 1, title: '被注释的人生', slug: 'ch-01', words: 4600 },
      { num: 2, title: 'NullPointerException', slug: 'ch-02', words: 5900 },
      { num: 3, title: '离开localhost', slug: 'ch-03', words: 8500 },
      { num: 4, title: 'Hello, World', slug: 'ch-04', words: 7600 },
      { num: 5, title: 'Stack Overflow', slug: 'ch-05', words: 6900 },
      { num: 6, title: 'Garbage Collection', slug: 'ch-06', words: 5700 },
      { num: 7, title: 'git init', slug: 'ch-07', words: 6500 },
      { num: 8, title: 'Runtime Exception', slug: 'ch-08', words: 4800 },
      { num: 9, title: 'Merge Conflict', slug: 'ch-09', words: 3900 },
      { num: 10, title: 'Pull Request Approved', slug: 'ch-10', words: 3300 },
      { num: 11, title: 'Dependencies Not Found', slug: 'ch-11', words: 3400 },
      { num: 12, title: 'O(n²) 的困境', slug: 'ch-12', words: 3300 },
      { num: 13, title: 'Breakpoint', slug: 'ch-13', words: 7700 },
      { num: 14, title: 'try { } catch { }', slug: 'ch-14', words: 6200 },
      { num: 15, title: 'Segmentation Fault', slug: 'ch-15', words: 6600 },
      { num: 16, title: 'Page Fault', slug: 'ch-16', words: 7000 },
      { num: 17, title: 'sudo rm -rf /doubt', slug: 'ch-17', words: 6300 },
      { num: 18, title: 'Version 1.0 — Release Notes', slug: 'ch-18', words: 7900 },
    ]
  },
  {
    id: 'vol-02',
    title: '编译之路',
    status: '规划中',
    chapters: []
  },
  {
    id: 'vol-03',
    title: '分布式战争',
    status: '规划中',
    chapters: []
  },
  {
    id: 'vol-04',
    title: '对齐危机',
    status: '规划中',
    chapters: []
  },
  {
    id: 'vol-05',
    title: '根权之战',
    status: '规划中',
    chapters: []
  },
  {
    id: 'vol-06',
    title: '开源天道',
    status: '规划中',
    chapters: []
  },
];
---

<Layout title="阅读">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <div class="mb-8">
      <h1 class="text-2xl font-bold font-mono">
        <span class="text-[#8b949e]">$</span> ls novel/
      </h1>
      <p class="text-[#8b949e] mt-2">总字数: 106K+ | 已发布: 18章 | 第一卷已完结</p>
    </div>

    <div class="mb-8 bg-[#161b22] rounded-lg border border-[#30363d] p-4">
      <div class="flex justify-between text-sm mb-2">
        <span class="text-[#8b949e]">总进度</span>
        <span class="text-[#58a6ff]">~11%</span>
      </div>
      <div class="h-2 bg-[#0d1117] rounded-full overflow-hidden">
        <div class="h-full bg-gradient-to-r from-[#58a6ff] via-[#3fb950] to-[#d29922] w-[11%]"></div>
      </div>
      <p class="text-xs text-[#8b949e] mt-2">106K / ~1,000K 字</p>
    </div>

    {volumes.map((volume) => (
      <div class="mb-6 bg-[#161b22] rounded-lg border border-[#30363d] overflow-hidden">
        <div class="flex items-center justify-between px-4 py-3 bg-[#0d1117] border-b border-[#30363d]">
          <h2 class="font-mono">
            <span class="text-[#8b949e]">./</span>
            <span class="text-[#58a6ff]">{volume.id}</span>
            <span class="text-[#8b949e]">/ {volume.title}</span>
          </h2>
          <span class={`text-xs px-2 py-1 rounded ${
            volume.status === '已完结' ? 'bg-[#238636] text-white' :
            volume.status === '连载中' ? 'bg-[#d29922] text-black' :
            'bg-[#21262d] text-[#8b949e]'
          }`}>
            {volume.status}
          </span>
        </div>
        {volume.chapters.length > 0 ? (
          <div class="divide-y divide-[#30363d]">
            {volume.chapters.map((chapter) => (
              <a
                href={basePath + '/read/' + volume.id + '/' + chapter.slug}
                class="flex items-center justify-between px-4 py-3 hover:bg-[#21262d] transition-colors no-underline"
              >
                <div class="flex items-center gap-3">
                  <span class="text-[#8b949e] font-mono text-sm w-8">{String(chapter.num).padStart(2, '0')}</span>
                  <span class="text-[#c9d1d9]">{chapter.title}</span>
                </div>
                <span class="text-[#8b949e] text-sm">~{(chapter.words / 1000).toFixed(1)}K</span>
              </a>
            ))}
          </div>
        ) : (
          <div class="px-4 py-8 text-center text-[#8b949e]">
            <p class="font-mono text-sm"># TODO: 待发布</p>
          </div>
        )}
      </div>
    ))}
  </div>
</Layout>
